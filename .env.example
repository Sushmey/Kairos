# Google Workspace — per-user OAuth via loopback callback (MCP + CLI)

# GCP Desktop OAuth client → register redirect URI:
# GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8766/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# After connect_google / kairos google connect --write-env:
# KAIROS_USER_ID=

# GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8766/callback
# GOOGLE_OAUTH_TIMEOUT_SECONDS=300
