# Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# MongoDB Atlas connection string
MONGODB_URI=
MONGODB_DB_NAME=kairos

# X API v2 — https://docs.x.com/x-api/users/get-bookmarks
# 1. Set X_CLIENT_ID from Developer Portal → App → Keys and tokens
# 2. Add callback URL in app settings: http://127.0.0.1:8765/callback
# 3. Run: kairos x auth
# 4. Refresh later: kairos x refresh
X_CLIENT_ID=
X_CLIENT_SECRET=
X_ACCESS_TOKEN=
X_REFRESH_TOKEN=
# Numeric id — set by `kairos x auth` or `kairos x whoami --write-env`
# X_USER_ID=
# X_OAUTH_REDIRECT_URI=http://127.0.0.1:8765/callback
# ENRICH_CONCURRENCY=10
# ENRICH_MAX_INPUT_CHARS=2000
# EMBEDDING_BACKEND=gemini   # gemini (fast, uses GEMINI_API_KEY) | local (sentence-transformers)
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_EMBEDDING_DIMENSIONS=768
# HDBSCAN_MIN_CLUSTER_SIZE=3

# Optional: override default models
# GEMINI_MODEL=gemini-3.5-flash
# GEMINI_FLASH_LITE_MODEL=gemini-3.1-flash-lite
# DIGEST_USE_GOOGLE_SEARCH=true

# Delivery adapters (comma-separated: web, os)
# DELIVERY_TARGETS=web
# WEB_BASE_URL=http://localhost:8420
# OS_DELIVERY_ENABLED=false
# MCP_SUPPRESS_OK_IN_CHAT=true
